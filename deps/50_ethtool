#!/bin/sh
#SOURCE: https://www.kernel.org/pub/software/network/ethtool/ethtool-7.0.tar.xz
#HASH: 2bfcc463662256302d7556ac0d1adecf45f85bdb

set -e
#set -x

build()
{
  if [ "x$1" = "xx86_64" ]
  then
    ./configure --prefix=/ --enable-netlink
  elif [ "x$1" = "xarm64" ]
  then
    ./configure --prefix=/ --enable-netlink --host aarch64-linux-gnu --build x86_64-pc-linux-gnu
  fi
  make $2
}

install()
{
  cp -f ethtool $1/sbin
}

binaries()
{
  ls ethtool
}
