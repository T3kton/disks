set -e
#set -x

build()
{
  if [ "x$1" = "xx86_64" ]
  then
    ./configure --prefix=/
  elif [ "x$1" = "xarm64" ]
  then
    ./configure --prefix=/ --host aarch64-linux-gnu --build x86_64-pc-linux-gnu
  fi
  make $2
  make install
}

install()
{
  :
}

